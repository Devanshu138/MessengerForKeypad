# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:replace_with_real_token

# Optional: backend port (default 3000)
PORT=3000

# Required: alias-to-chat map used by /send route
# Format: alias:chatId pairs separated by commas
# Example: alice:123456789,bob:987654321
ALIAS_MAP=alice:123456789
